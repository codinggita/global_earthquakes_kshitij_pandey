# Server Configuration
PORT=5000
NODE_ENV=development
API_VERSION=v1

# MongoDB Configuration
# Local: mongodb://localhost:27017/global_earthquakes
# Atlas: mongodb+srv://<username>:<password>@cluster0.mongodb.net/global_earthquakes
MONGODB_URI=mongodb://127.0.0.1:27017/global_earthquakes

# JWT Authentication
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production
JWT_EXPIRE=1h
JWT_REFRESH_SECRET=another_super_secret_refresh_key_change_me_in_production
JWT_REFRESH_EXPIRE=7d

# Security Settings
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX=100 # limit each IP to 100 requests per windowMs

# SMTP Email Settings (for verification and password resets)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=no-reply@globalearthquakeanalytics.com
FROM_NAME=Global Earthquake Analytics

# Logging
LOG_LEVEL=info
